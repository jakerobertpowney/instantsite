APP_NAME=321Sites
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://321sites.test
APP_DOMAIN=321sites.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@321sites.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Stripe / Cashier ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_

# Create a webhook endpoint in Stripe Dashboard → Developers → Webhooks
# pointing to: https://yourdomain.com/stripe/webhook
# Then paste the signing secret here:
STRIPE_WEBHOOK_SECRET=whsec_

# Create a Product in Stripe Dashboard → Products, add a recurring price,
# and paste the price_XXXXXX ID here:
STRIPE_PRICE_ID=price_

# Currency for billing (default: gbp)
CASHIER_CURRENCY=gbp

# AI Features (Claude Haiku via Anthropic API)
# Used for: description generation, services extraction, and AI-generated service suggestions
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Places API key (for business search and details)
GOOGLE_API_KEY=

# Pexels API key — enables stock photo search in the header background picker
# Free at: https://www.pexels.com/api/ (no credit card required)
PEXELS_API_KEY=

# ─── Domain provider OAuth (Tier 2 — auto DNS configuration) ──────────────────
# Cloudflare OAuth app — register at: https://dash.cloudflare.com/profile/api-tokens
# Create an "OAuth 2.0 Application" and set the Redirect URI to:
#   {APP_URL}/dashboard/domain/cloudflare/callback
# Required scopes: account:read, zone.dns:edit
# Leave blank to hide the "Connect Cloudflare" button in the dashboard.
CLOUDFLARE_CLIENT_ID=
CLOUDFLARE_CLIENT_SECRET=
CLOUDFLARE_REDIRECT_URI="${APP_URL}/dashboard/domain/cloudflare/callback"

# GoDaddy API credentials are entered by users in the dashboard UI.
# No server-side env var is needed for GoDaddy.
