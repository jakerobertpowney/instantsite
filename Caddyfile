# ── 321Sites — production Caddyfile ─────────────────────────────────────────
#
# Automatic HTTPS for the app's own domain, its *.321sites.com subdomains, and
# every customer custom domain. Caddy obtains and renews Let's Encrypt certs
# ON DEMAND — i.e. the first time a request arrives for a hostname it doesn't
# yet have a cert for — and the `ask` endpoint below tells Caddy which
# hostnames are allowed a cert, so random domains pointed at this server can't
# exhaust Let's Encrypt rate limits.
#
# Placeholders to change for your environment are marked with CHANGE ME.

{
	# Let's Encrypt account email + expiry notices.
	email admin@321sites.com          # CHANGE ME

	# Caddy only requests a certificate for a hostname if this endpoint
	# returns a 2xx. It's served by the internal HTTP listener below so it
	# stays private to the server.
	on_demand_tls {
		ask http://127.0.0.1:9000/internal/tls-check
	}
}

# ── Internal HTTP listener (localhost only) ─────────────────────────────────
# Exists purely so the on_demand_tls `ask` check has an HTTP endpoint to call.
# Not reachable from the internet.
http://127.0.0.1:9000 {
	root * /var/www/instantsite/public          # CHANGE ME (app public/ path)
	php_fastcgi unix//run/php/php8.2-fpm.sock    # CHANGE ME (php-fpm socket)
}

# ── Public site: app domain + subdomains + custom domains ───────────────────
# A single catch-all https:// block with on-demand TLS. The `ask` endpoint
# gates which hostnames actually get a certificate.
https:// {
	tls {
		on_demand
	}

	root * /var/www/instantsite/public          # CHANGE ME (app public/ path)
	encode zstd gzip
	php_fastcgi unix//run/php/php8.2-fpm.sock    # CHANGE ME (php-fpm socket)
	file_server
}

# ── Notes ───────────────────────────────────────────────────────────────────
# • If you serve the app with Octane / FrankenPHP / `php artisan serve` instead
#   of php-fpm, replace the `php_fastcgi` lines with
#   `reverse_proxy 127.0.0.1:8000` and point the `ask` URL at that same port
#   (you can then drop the separate :9000 listener).
# • Ports 80 and 443 must be open — port 80 is required for the ACME challenge.
# • The first request to a brand-new custom domain is slightly slower while the
#   certificate is issued; subsequent requests are instant.
